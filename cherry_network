#!/bin/bash

# Цвета для интерфейса
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
NC='\033[0m'

# === АВТОМАТИЧЕСКАЯ ДЕТЕКЦИЯ ===
DETECTED_INT=$(ip route | grep default | awk '{print $5}' | head -n1)
DETECTED_GW=$(ip route | grep default | awk '{print $3}' | head -n1)
INTERFACE_DEFAULT=${DETECTED_INT:-"eth0"}
GATEWAY_DEFAULT=${DETECTED_GW:-"192.168.0.1"}

show_header() {
    clear
    echo -e "${BLUE}===========================================${NC}"
    echo -e "${BLUE}    GotBot VPN Admin Panel (v3.0)          ${NC}"
    echo -e "${BLUE}===========================================${NC}"
    echo -e "Система: Интерфейс [${YELLOW}$INTERFACE_DEFAULT${NC}], Шлюз [${YELLOW}$GATEWAY_DEFAULT${NC}]"
}

# 1. Настройка сети
setup_network() {
    echo -e "\n${YELLOW}[ Настройка Floating IP ]${NC}"
    read -p "Введите Floating IP: " NEW_IP </dev/tty
    if [[ -z "$NEW_IP" ]]; then echo -e "${RED}Ошибка: IP не может быть пустым!${NC}"; sleep 1; return; fi

    read -p "Введите интерфейс [$INTERFACE_DEFAULT]: " USER_INT </dev/tty
    FINAL_INT=${USER_INT:-$INTERFACE_DEFAULT}

    read -p "Введите Gateway [$GATEWAY_DEFAULT]: " USER_GW </dev/tty
    FINAL_GW=${USER_GW:-$GATEWAY_DEFAULT}

    echo -e "\n${BLUE}Создание сервиса автозагрузки...${NC}"
    cat <<EOF > /etc/systemd/system/floating-ip.service
[Unit]
Description=Setup Floating IP Routing for GotBot VPN
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStartPre=/usr/bin/sleep 5
ExecStart=/sbin/ip addr add $NEW_IP/32 dev $FINAL_INT
ExecStart=/sbin/ip route add $FINAL_GW dev $FINAL_INT table 100
ExecStart=/sbin/ip route add default via $FINAL_GW dev $FINAL_INT table 100
ExecStart=/sbin/ip rule add from $NEW_IP table 100

[Install]
WantedBy=multi-user.target
EOF

    systemctl daemon-reload
    systemctl enable floating-ip.service
    ip addr add $NEW_IP/32 dev $FINAL_INT 2>/dev/null
    systemctl restart floating-ip.service

    echo -ne "Проверка связи... "
    if ping -c 3 -I $NEW_IP 8.8.8.8 &> /dev/null; then
        echo -e "${GREEN}✅ OK!${NC}"
    else
        echo -e "${RED}❌ FAIL (Проверьте панель хостера)${NC}"
    fi
    read -p "Нажмите Enter..." </dev/tty
}

# 2. Проверка статуса
check_status() {
    echo -e "\n${YELLOW}[ Текущий статус системы ]${NC}"
    
    echo -n "Служба сети:  "
    systemctl is-active --quiet floating-ip.service && echo -e "${GREEN}ACTIVE${NC}" || echo -e "${RED}INACTIVE${NC}"
    
    echo -n "Caddy:         "
    systemctl is-active --quiet caddy && echo -e "${GREEN}RUNNING${NC}" || echo -e "${RED}STOPPED${NC}"
    
    echo -n "Xray (Docker): "
    if command -v docker &> /dev/null && docker ps | grep -q remnanode; then
        echo -e "${GREEN}RUNNING${NC}"
    else
        echo -e "${RED}STOPPED/NOT INSTALLED${NC}"
    fi

    # Проверка внешнего выхода
    EXT_IP=$(curl -s --connect-timeout 2 ifconfig.me)
    echo -e "Внешний IP:    ${PURPLE}${EXT_IP:-"Timeout"}${NC}"
    
    echo -e "\n${BLUE}Все активные IP:${NC}"
    ip addr | grep -E "inet |scope global" | grep -v "127.0.0.1"
    
    read -p "Нажмите Enter..." </dev/tty
}

# 3. Просмотр логов
show_logs() {
    echo -e "\n${YELLOW}[ Выберите службу ]${NC}"
    echo "1) Caddy (SSL/Reverse Proxy)"
    echo "2) Xray (Docker)"
    echo "3) Назад"
    read -p ">> " log_opt </dev/tty
    case $log_opt in
        1) journalctl -u caddy -n 50 --no-pager ;;
        2) docker logs --tail 50 remnanode ;;
        *) return ;;
    esac
    read -p "Нажмите Enter..." </dev/tty
}

# 4. Установка инструментов
install_tools() {
    echo -e "\n${YELLOW}[ Начинаю установку Docker и Caddy... ]${NC}"
    apt update && apt install -y curl sudo jq gnupg
    
    # Docker
    if ! command -v docker &> /dev/null; then
        echo -e "${BLUE}Ставлю Docker...${NC}"
        curl -fsSL https://get.docker.com | sh
    fi

    # Caddy
    if ! command -v caddy &> /dev/null; then
        echo -e "${BLUE}Ставлю Caddy...${NC}"
        curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' | sudo gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
        curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' | sudo tee /etc/apt/sources.list.d/caddy-stable.list
        apt update && apt install -y caddy
    fi
    echo -e "${GREEN}Готово!${NC}"
    sleep 2
}

# 5. Удаление
remove_network() {
    echo -e "\n${RED}[ Удаление настроек ]${NC}"
    read -p "Точно удалить службу и правила? (y/n): " CONFIRM </dev/tty
    if [[ $CONFIRM == "y" ]]; then
        systemctl stop floating-ip.service 2>/dev/null
        systemctl disable floating-ip.service 2>/dev/null
        rm -f /etc/systemd/system/floating-ip.service
        systemctl daemon-reload
        echo -e "${GREEN}Всё чисто.${NC}"
    fi
    sleep 1
}

# Основной цикл
while true; do
    show_header
    echo -e "1) ${GREEN}Настроить Floating IP (Сеть)${NC}"
    echo -e "2) Проверить статус и IP"
    echo -e "3) ${YELLOW}Посмотреть логи (Caddy/Xray)${NC}"
    echo -e "4) ${BLUE}Установить Docker & Caddy${NC}"
    echo -e "5) Удалить настройки сети"
    echo -e "6) Выход"
    echo -ne "\nВыберите пункт: "
    read opt </dev/tty

    case $opt in
        1) setup_network ;;
        2) check_status ;;
        3) show_logs ;;
        4) install_tools ;;
        5) remove_network ;;
        6) clear; exit 0 ;;
        *) echo -e "${RED}Неверный пункт${NC}"; sleep 1 ;;
    esac
done
