#!/bin/bash

# Цвета для интерфейса
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# === АВТОМАТИЧЕСКАЯ ДЕТЕКЦИЯ (Универсальность) ===
# Определяем основной интерфейс и шлюз через таблицу маршрутов
DETECTED_INT=$(ip route | grep default | awk '{print $5}' | head -n1)
DETECTED_GW=$(ip route | grep default | awk '{print $3}' | head -n1)

# Если не удалось определить, ставим заглушки
INTERFACE_DEFAULT=${DETECTED_INT:-"eth0"}
GATEWAY_DEFAULT=${DETECTED_GW:-"192.168.0.1"}

show_header() {
    clear
    echo -e "${BLUE}===========================================${NC}"
    echo -e "${BLUE}    GotBot Multi-Provider Net Manager      ${NC}"
    echo -e "${BLUE}===========================================${NC}"
    echo -e "Система: Интерфейс [${YELLOW}$INTERFACE_DEFAULT${NC}], Шлюз [${YELLOW}$GATEWAY_DEFAULT${NC}]"
}

setup_network() {
    echo -e "\n${YELLOW}[ Настройка новой ноды ]${NC}"
    
    # 1. Запрос IP
    read -p "Введите Floating IP: " NEW_IP </dev/tty
    if [[ -z "$NEW_IP" ]]; then
        echo -e "${RED}Ошибка: IP не может быть пустым!${NC}"
        sleep 2; return
    fi

    # 2. Запрос Интерфейса (с подсказкой)
    read -p "Введите интерфейс [$INTERFACE_DEFAULT]: " USER_INT </dev/tty
    FINAL_INT=${USER_INT:-$INTERFACE_DEFAULT}

    # 3. Запрос Шлюза (с подсказкой)
    read -p "Введите Gateway [$GATEWAY_DEFAULT]: " USER_GW </dev/tty
    FINAL_GW=${USER_GW:-$GATEWAY_DEFAULT}

    echo -e "\n${BLUE}1. Создание сервиса для $FINAL_INT...${NC}"
    cat <<EOF > /etc/systemd/system/floating-ip.service
[Unit]
Description=Setup Floating IP Routing for GotBot VPN
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStartPre=/usr/bin/sleep 5
ExecStart=/sbin/ip addr add $NEW_IP/32 dev $FINAL_INT
ExecStart=/sbin/ip route add $FINAL_GW dev $FINAL_INT table 100
ExecStart=/sbin/ip route add default via $FINAL_GW dev $FINAL_INT table 100
ExecStart=/sbin/ip rule add from $NEW_IP table 100

[Install]
WantedBy=multi-user.target
EOF

    echo -e "${BLUE}2. Активация настроек...${NC}"
    systemctl daemon-reload
    systemctl enable floating-ip.service
    
    # Применяем настройки «на лету» (игнорируем ошибку если IP уже есть)
    ip addr add $NEW_IP/32 dev $FINAL_INT 2>/dev/null
    systemctl restart floating-ip.service

    echo -e "${BLUE}3. Проверка связи через $NEW_IP...${NC}"
    if ping -c 3 -I $NEW_IP 8.8.8.8 &> /dev/null; then
        echo -e "${GREEN}✅ УСПЕХ: Сеть настроена, пинг идет!${NC}"
    else
        echo -e "${RED}❌ ОШИБКА: Пинг не прошел через $NEW_IP.${NC}"
        echo -e "${YELLOW}Проверьте, привязан ли IP в панели провайдера.${NC}"
    fi
    read -p "Нажмите Enter, чтобы вернуться в меню..." </dev/tty
}

check_status() {
    echo -e "\n${YELLOW}[ Текущий статус системы ]${NC}"
    
    echo -n "Сервис сети: "
    systemctl is-active --quiet floating-ip.service && echo -e "${GREEN}ACTIVE${NC}" || echo -e "${RED}INACTIVE${NC}"
    
    echo -n "Caddy:        "
    systemctl is-active --quiet caddy && echo -e "${GREEN}RUNNING${NC}" || echo -e "${RED}STOPPED${NC}"
    
    echo -n "Xray (Docker): "
    if command -v docker &> /dev/null && docker ps | grep -q remnanode; then
        echo -e "${GREEN}RUNNING${NC}"
    else
        echo -e "${RED}STOPPED/NOT INSTALLED${NC}"
    fi
    
    echo -e "\n${BLUE}Активные IP на интерфейсах:${NC}"
    ip addr | grep -E "inet |scope global" | grep -v "127.0.0.1"
    
    read -p "Нажмите Enter, чтобы вернуться в меню..." </dev/tty
}

remove_network() {
    echo -e "\n${RED}[ Удаление настроек сети ]${NC}"
    read -p "Вы уверены, что хотите удалить сервис и правила? (y/n): " CONFIRM </dev/tty
    if [[ $CONFIRM == "y" ]]; then
        systemctl stop floating-ip.service 2>/dev/null
        systemctl disable floating-ip.service 2>/dev/null
        rm -f /etc/systemd/system/floating-ip.service
        systemctl daemon-reload
        echo -e "${GREEN}Конфигурация удалена.${NC}"
    fi
    sleep 2
}

# Основной цикл меню
while true; do
    show_header
    echo -e "1) ${GREEN}Настроить сеть (Floating IP)${NC}"
    echo -e "2) Проверить статус (Network/Caddy/Docker)"
    echo -e "3) ${RED}Удалить настройки сети${NC}"
    echo -e "4) Выход"
    echo -ne "\nВыберите пункт: "
    read opt </dev/tty

    case $opt in
        1) setup_network ;;
        2) check_status ;;
        3) remove_network ;;
        4) clear; exit 0 ;;
        *) echo -e "${RED}Неверный пункт${NC}"; sleep 1 ;;
    esac
done
