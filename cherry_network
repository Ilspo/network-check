#!/bin/bash

# Цвета для терминала
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}=== Cherry Servers Network Fixer for GotBot VPN ===${NC}"

# Интерактивный ввод данных
read -p "Введите ваш Floating IP (новый адрес): " NEW_IP
read -p "Введите Gateway (обычно 192.168.0.1): " GATEWAY
INTERFACE="eth0"

# 1. Привязка IP к интерфейсу
echo -e "\n${YELLOW}[1/3] Проверка сетевого адреса...${NC}"
if ip addr show $INTERFACE | grep -q "$NEW_IP"; then
    echo -e "${GREEN}✅ IP $NEW_IP уже на интерфейсе.${NC}"
else
    echo -e "Добавляю IP $NEW_IP на $INTERFACE..."
    sudo ip addr add $NEW_IP/32 dev $INTERFACE
fi

# 2. Настройка маршрутов (Table 100)
echo -e "\n${YELLOW}[2/3] Настройка таблицы маршрутизации...${NC}"
# Проверяем наличие таблицы и правил, чтобы не дублировать
if ip rule show | grep -q "from $NEW_IP lookup 100"; then
    echo -e "${GREEN}✅ Маршруты уже настроены.${NC}"
else
    echo -e "Создаю правила для таблицы 100..."
    sudo ip route add $GATEWAY dev $INTERFACE table 100 2>/dev/null
    sudo ip route add default via $GATEWAY dev $INTERFACE table 100 2>/dev/null
    sudo ip rule add from $NEW_IP table 100
fi

# 3. Фиксация в Systemd (Автозагрузка)
echo -e "\n${YELLOW}[3/3] Настройка автозагрузки...${NC}"
SERVICE_FILE="/etc/systemd/system/floating-ip.service"

cat <<EOF | sudo tee $SERVICE_FILE > /dev/null
[Unit]
Description=Setup Floating IP Routing for Cherry Servers
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStartPre=/usr/bin/sleep 5
ExecStart=/sbin/ip addr add $NEW_IP/32 dev $INTERFACE
ExecStart=/sbin/ip route add $GATEWAY dev $INTERFACE table 100
ExecStart=/sbin/ip route add default via $GATEWAY dev $INTERFACE table 100
ExecStart=/sbin/ip rule add from $NEW_IP table 100

[Install]
WantedBy=multi-user.target
EOF

sudo systemctl daemon-reload
sudo systemctl enable floating-ip.service
echo -e "${GREEN}✅ Сервис создан и добавлен в автозагрузку.${NC}"

# Проверка пинга через конкретный IP
echo -e "\n${YELLOW}Проверка связи через новый IP...${NC}"
if ping -I $NEW_IP -c 3 8.8.8.8 &> /dev/null; then
    echo -e "${GREEN}🚀 ПОБЕДА! Сеть полностью готова к работе.${NC}"
else
    echo -e "${RED}❌ Пинг не прошел. Проверьте привязку IP в панели хостинга.${NC}"
fi
