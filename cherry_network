#!/bin/bash

# Цвета для интерфейса
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Функция заголовка
show_header() {
    clear
    echo -e "${BLUE}===========================================${NC}"
    echo -e "${BLUE}    GotBot VPN Infrastructure Manager      ${NC}"
    echo -e "${BLUE}===========================================${NC}"
}

# Функция настройки сети
setup_network() {
    echo -e "\n${YELLOW}[ Настройка новой ноды ]${NC}"
    
    # Запрос данных с вводом по умолчанию
    read -p "Введите Floating IP: " NEW_IP </dev/tty
    read -p "Введите Gateway [192.168.0.1]: " GATEWAY </dev/tty
    GATEWAY=${GATEWAY:-192.168.0.1}
    INTERFACE="eth0"

    echo -e "\n${BLUE}1. Создание сервиса автозагрузки...${NC}"
    cat <<EOF > /etc/systemd/system/floating-ip.service
[Unit]
Description=Setup Floating IP Routing for Cherry Servers
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStartPre=/usr/bin/sleep 5
ExecStart=/sbin/ip addr add $NEW_IP/32 dev $INTERFACE
ExecStart=/sbin/ip route add $GATEWAY dev $INTERFACE table 100
ExecStart=/sbin/ip route add default via $GATEWAY dev $INTERFACE table 100
ExecStart=/sbin/ip rule add from $NEW_IP table 100

[Install]
WantedBy=multi-user.target
EOF

    echo -e "${BLUE}2. Активация настроек...${NC}"
    systemctl daemon-reload
    systemctl enable floating-ip.service
    
    # Пытаемся запустить (с очисткой старых правил, если они были)
    ip addr add $NEW_IP/32 dev $INTERFACE 2>/dev/null
    systemctl restart floating-ip.service

    echo -e "${BLUE}3. Проверка связи...${NC}"
    if ping -c 3 -I $NEW_IP 8.8.8.8 &> /dev/null; then
        echo -e "${GREEN}✅ УСПЕХ: Сеть настроена, пинг идет!${NC}"
    else
        echo -e "${RED}❌ ОШИБКА: Пинг не прошел. Проверьте IP в панели Cherry.${NC}"
    fi
    read -p "Нажмите Enter, чтобы вернуться в меню..." </dev/tty
}

# Функция проверки статуса
check_status() {
    echo -e "\n${YELLOW}[ Текущий статус системы ]${NC}"
    
    echo -n "Сервис сети: "
    systemctl is-active --quiet floating-ip.service && echo -e "${GREEN}ACTIVE${NC}" || echo -e "${RED}INACTIVE${NC}"
    
    echo -n "Caddy:        "
    systemctl is-active --quiet caddy && echo -e "${GREEN}RUNNING${NC}" || echo -e "${RED}STOPPED${NC}"
    
    echo -n "Xray Node:    "
    docker ps 2>/dev/null | grep -q remnanode && echo -e "${GREEN}RUNNING${NC}" || echo -e "${RED}STOPPED${NC}"
    
    echo -e "\n${BLUE}Активные IP на eth0:${NC}"
    ip addr show eth0 | grep "inet "
    
    read -p "Нажмите Enter, чтобы вернуться в меню..." </dev/tty
}

# Функция удаления настроек
remove_network() {
    echo -e "\n${RED}[ Удаление настроек сети ]${NC}"
    read -p "Вы уверены? (y/n): " CONFIRM </dev/tty
    if [[ $CONFIRM == "y" ]]; then
        systemctl stop floating-ip.service
        systemctl disable floating-ip.service
        rm -f /etc/systemd/system/floating-ip.service
        systemctl daemon-reload
        echo -e "${GREEN}Настройки удалены. Не забудьте вручную убрать IP, если он остался.${NC}"
    fi
    sleep 2
}

# Основной цикл меню
while true; do
    show_header
    echo -e "1) ${GREEN}Настроить сеть (Floating IP)${NC}"
    echo -e "2) Проверить статус (Network/Caddy/Docker)"
    echo -e "3) ${RED}Удалить настройки сети${NC}"
    echo -e "4) Выход"
    echo -ne "\nВыберите пункт: "
    read opt </dev/tty

    case $opt in
        1) setup_network ;;
        2) check_status ;;
        3) remove_network ;;
        4) exit 0 ;;
        *) echo -e "${RED}Неверный пункт${NC}"; sleep 1 ;;
    esac
done
